# Translation pipeline — Eternal Codex (EN → IS)
# Copy to .env and fill in your key. Never commit .env.
GOOGLE_AI_API_KEY=your_google_ai_studio_key_here

# Pinned model for production runs (DO NOT use -latest in production —
# pin a specific preview ID so model routing updates don't shift dialect mid-run):
TRANSLATION_MODEL=gemini-3-flash-preview

# Concurrency cap (Gemini Flash 3 Preview tolerates 4 well at low quotas; bump to 8 if quota allows):
TRANSLATION_CONCURRENCY=4
