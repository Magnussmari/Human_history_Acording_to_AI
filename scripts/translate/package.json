{
  "name": "eternal-codex-translate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Isolated translation pipeline for the Eternal Codex corpus (EN → IS).",
  "scripts": {
    "validate": "tsx validate.ts",
    "run:is": "tsx run.ts --locale is",
    "dry-run:is": "tsx run.ts --locale is --files ../../outputs/json/-1.json,../../outputs/json/0.json,../../outputs/json/2025.json"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "ajv": "^8.18.0",
    "dotenv": "^16.4.5",
    "p-limit": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
